{
    "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
    "include": [
        "electron-vite.config.*",
        "src/main/**/*",
        "src/preload/**/*",
        "src/shared/**/*"
    ],
    "compilerOptions": {
        "composite": true,
        "outDir": "out",
        "paths": {
            "@shared/*": [
                "./src/shared/*"
            ],
            "@main/*": [
                "./src/main/*"
            ]
        }
    }
}